# OpenAI — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Facebook Messenger Platform — get from https://developers.facebook.com/apps

# Page Access Token: Generated per Facebook Page in App Dashboard > Messenger > Settings
FACEBOOK_PAGE_ACCESS_TOKEN=your-page-access-token-here

# App Secret: Found in App Dashboard > Settings > Basic. Used to verify webhook signatures.
FACEBOOK_APP_SECRET=your-app-secret-here

# Verify Token: A random string YOU choose. Must match what you enter when subscribing the webhook.
FACEBOOK_VERIFY_TOKEN=pick-any-random-string-here

# App ID: Found in App Dashboard top bar.
FACEBOOK_APP_ID=your-numeric-app-id-here