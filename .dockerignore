# =============================================================================
# .dockerignore — files NOT copied into Docker build context
#
# Smaller context = faster builds + smaller images.
# Anything in .gitignore should generally be here too, plus dev-only files.
# =============================================================================

# --- Python virtual environments (huge, host-specific) ---
.venv/
venv/
env/
ENV/

# --- Python compilation artifacts ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# --- Environment / secrets (provided at runtime, NEVER baked in) ---
.env
.env.local
*.env

# --- IDE / editor metadata ---
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# --- Git ---
.git/
.gitignore
.gitattributes

# --- Logs (generated at runtime, container has its own /app/logs) ---
logs/
*.log

# --- Test reports (regenerated on demand) ---
tests/catalog_report_*.md

# --- Vector store (regenerated by entrypoint on first startup) ---
vector_store/

# --- Documentation / readme ---
README.md
*.md

# --- Docker files themselves (not needed inside container) ---
Dockerfile
.dockerignore
docker-compose.yml

# --- CI/CD config (lives in .github, not in image) ---
.github/

# --- OS / misc ---
.pytest_cache/
.mypy_cache/
htmlcov/
.coverage
